{
  "name": "yj-timetable-widget",
  "version": "1.0.0",
  "description": "Yongjeong timetable desktop widget",
  "author": "하헌휘",
  "main": "widget/main.js",
  "private": true,
  "scripts": {
    "start:widget": "electron .",
    "dist:win": "electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "kr.yjms.timetable.widget",
    "productName": "YJ Timetable Widget",
    "files": [
      "assets/**/*",
      "src/storage.js",
      "src/supabase-config.js",
      "widget/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/logo.png"
    },
    "nsis": {
      "artifactName": "YJ-Timetable-Widget-Setup.exe",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "YJ Timetable Widget"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
